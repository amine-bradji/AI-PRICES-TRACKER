# Optional: override the source of foreign-exchange rates.
# Default (key-less): https://open.er-api.com/v6/latest/USD
FX_API_BASE=https://open.er-api.com/v6/latest/USD

# Optional: minimum seconds between Update refreshes (server-side cooldown).
# Lowering this is not recommended - it protects upstream FX + provider servers.
UPDATE_COOLDOWN_SECONDS=60
